# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Embeddings ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector Store (Qdrant Cloud — free tier works fine) ───────────────────────
QDRANT_URL=https://xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=persona_knowledge

# ─── Voice Agent (Vapi) ───────────────────────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-phone-number-id
VAPI_ASSISTANT_ID=your-assistant-id          # filled after creating assistant

# ─── Calendar (Cal.com) ───────────────────────────────────────────────────────
CALCOM_API_KEY=cal_live_...
CALCOM_EVENT_TYPE_SLUG=30min                 # slug from your Cal.com event type
CALCOM_USERNAME=your-calcom-username

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                         # optional; raises rate limit
GITHUB_USERNAME=your-github-username

# ─── App ──────────────────────────────────────────────────────────────────────
API_BASE_URL=https://your-backend.railway.app
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
INGEST_SECRET=a-long-random-secret-for-the-ingest-endpoint
